<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArgoBooks.ViewModels"
             xmlns:controls="using:ArgoBooks.Controls"
             xmlns:local="using:ArgoBooks.Converters"
             xmlns:loc="using:ArgoBooks.Localization"
             xmlns:icons="using:ArgoBooks"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ArgoBooks.Modals.PurchaseOrdersModals"
             x:DataType="vm:PurchaseOrdersModalsViewModel">

    <Panel>
        <!-- Add/Edit Order Modal -->
        <controls:ModalOverlay IsOpen="{Binding IsAddModalOpen}"
                               ClosingCommand="{Binding RequestCloseAddModalCommand}">
            <controls:ModalOverlay.ModalContent>
                <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Width="700"
                    MaxHeight="700"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Modal Header -->
                    <Border Grid.Row="0" Padding="24,20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding AddModalTitle}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{loc:Loc 'Create a purchase order for your supplier'}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1" Classes="icon-button" Command="{Binding CloseAddModalCommand}">
                                <PathIcon Data="{x:Static icons:Icons.Close}" Width="20" Height="20" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Modal Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24" Spacing="16">
                            <!-- Supplier Selection -->
                            <StackPanel Spacing="6">
                                <TextBlock FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <Run Text="{loc:Loc 'Supplier'}" /><Run Text=" *" Foreground="{DynamicResource ErrorBrush}" />
                                </TextBlock>
                                <controls:SearchableDropdown ItemsSource="{Binding AvailableSuppliers}"
                                                            SelectedItem="{Binding SelectedSupplier}"
                                                            DisplayMemberPath="Name"
                                                            Placeholder="{loc:Loc 'Search suppliers...'}"
                                                            ShowAddNew="False"
                                                            EmptyMessage="{loc:Loc 'No suppliers available.'}"
                                                            EmptyCreateLinkText="{loc:Loc 'Create one'}"
                                                            EmptyCreateCommand="{Binding OpenCreateSupplierCommand}" />
                                <TextBlock Text="{loc:Loc 'Please select a supplier.'}"
                                           FontSize="12" Foreground="{DynamicResource ErrorBrush}"
                                           IsVisible="{Binding HasSupplierError}" />
                            </StackPanel>

                            <!-- Dates Row -->
                            <Grid ColumnDefinitions="*,16,*">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="{loc:Loc 'Order Date'}" /><Run Text=" *" Foreground="{DynamicResource ErrorBrush}" />
                                    </TextBlock>
                                    <DatePicker SelectedDate="{Binding OrderDate}"
                                                Classes="form-datepicker"
                                                HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}">
                                        <Run Text="{loc:Loc 'Expected Delivery'}" /><Run Text=" *" Foreground="{DynamicResource ErrorBrush}" />
                                    </TextBlock>
                                    <DatePicker SelectedDate="{Binding ExpectedDeliveryDate}"
                                                Classes="form-datepicker"
                                                HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>

                            <!-- Line Items Section -->
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{loc:Loc 'Line Items'}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Classes="secondary-button"
                                            Command="{Binding AddLineItemCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <PathIcon Data="{x:Static icons:Icons.Add}" Width="14" Height="14" />
                                            <TextBlock Text="{loc:Loc 'Add Item'}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Line Items Header -->
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        CornerRadius="6"
                                        Padding="12,8"
                                        IsVisible="{Binding LineItems.Count, Converter={x:Static local:IntConverters.IsPositive}}">
                                    <Grid ColumnDefinitions="2*,80,90,100,40">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                            <TextBlock Text="{loc:Loc 'Product'}" FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextTertiaryBrush}" />
                                            <TextBlock Text=" *" FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource DangerBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{loc:Loc 'Qty'}" FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="2" Text="{loc:Loc 'Unit Cost'}" FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="3" Text="{loc:Loc 'Total'}" FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,12,0" />
                                    </Grid>
                                </Border>

                                <!-- Line Items List -->
                                <ItemsControl ItemsSource="{Binding LineItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:OrderLineItemViewModel">
                                            <Border Padding="12,8"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid ColumnDefinitions="2*,80,90,100,40">
                                                    <controls:SearchableDropdown Grid.Column="0"
                                                             Classes="compact"
                                                             Margin="0,0,8,0"
                                                             ItemsSource="{Binding $parent[ItemsControl].((vm:PurchaseOrdersModalsViewModel)DataContext).AvailableProducts}"
                                                             SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                                             DisplayMemberPath="Name"
                                                             Placeholder="{loc:Loc 'Search for a product...'}"
                                                             ShowAddNew="False"
                                                             EmptyMessage="{loc:Loc 'No products found.'}"
                                                             EmptyCreateLinkText="{loc:Loc 'Create one'}"
                                                             EmptyCreateCommand="{Binding $parent[ItemsControl].((vm:PurchaseOrdersModalsViewModel)DataContext).OpenCreateProductCommand}"
                                                             HasError="{Binding HasProductError}"
                                                             ErrorMessage="{loc:Loc 'Please select a product.'}" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Quantity, Mode=TwoWay}"
                                                             Classes="form-input-compact"
                                                             HorizontalContentAlignment="Center"
                                                             VerticalAlignment="Top"
                                                             Margin="0,0,8,0"
                                                             MaxLength="7" />
                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding UnitCost, Mode=TwoWay}"
                                                             Classes="form-input-compact"
                                                             HorizontalContentAlignment="Center"
                                                             VerticalAlignment="Top"
                                                             Margin="0,0,8,0"
                                                             MaxLength="13" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding TotalDisplay}"
                                                               FontSize="14"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,0,12,0" />
                                                    <Button Grid.Column="4"
                                                            Classes="icon-button danger"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            IsVisible="{Binding $parent[ItemsControl].((vm:PurchaseOrdersModalsViewModel)DataContext).LineItems.Count, Converter={x:Static local:IntConverters.IsGreaterThanOne}}"
                                                            Command="{Binding $parent[ItemsControl].((vm:PurchaseOrdersModalsViewModel)DataContext).RemoveLineItemCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="{loc:Loc 'Remove item'}">
                                                        <PathIcon Data="{x:Static icons:Icons.Delete}" Width="14" Height="14" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State for Line Items -->
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        CornerRadius="8"
                                        Padding="24,16"
                                        IsVisible="{Binding LineItems.Count, Converter={x:Static local:IntConverters.IsZero}}">
                                    <TextBlock Text="{loc:Loc 'No line items added. Click \'Add Item\' to add products.'}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                </Border>
                            </StackPanel>

                            <!-- Totals Section -->
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Loc 'Subtotal'}" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SubtotalDisplay}" FontWeight="Medium" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,120">
                                        <TextBlock Grid.Column="0" Text="{loc:Loc 'Shipping Cost'}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding ShippingCost, Mode=TwoWay}"
                                                 Classes="form-input-compact"
                                                 HorizontalAlignment="Right"
                                                 MaxLength="13" />
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,4" />
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{loc:Loc 'Total'}" FontWeight="SemiBold" FontSize="16" />
                                        <TextBlock Grid.Column="1" Text="{Binding TotalDisplay}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource PrimaryBrush}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Notes -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="{loc:Loc 'Notes'}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBox Text="{Binding Notes, Mode=TwoWay}"
                                         Classes="form-input"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="60"
                                         MaxHeight="100"
                                         PlaceholderText="{loc:Loc 'Additional notes for this order...'}"
                                         MaxLength="500" />
                            </StackPanel>

                            <!-- Error Message -->
                            <TextBlock Text="{Binding AddModalError}"
                                       FontSize="12"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       IsVisible="{Binding AddModalError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Modal Footer -->
                    <Border Grid.Row="2" Padding="24,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                            <Button Classes="secondary-button" Content="{loc:Loc 'Cancel'}" Command="{Binding CloseAddModalCommand}" />
                            <Button Classes="secondary-button" Content="{loc:Loc 'Save Order'}" Command="{Binding SaveOrderCommand}" />
                            <Button Classes="primary-button" Content="{loc:Loc 'Save &amp; Preview'}" Command="{Binding SaveAndPreviewOrderCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>
                </Border>
            </controls:ModalOverlay.ModalContent>
        </controls:ModalOverlay>

        <!-- View Order Modal -->
        <controls:ModalOverlay IsOpen="{Binding IsViewModalOpen}">
            <controls:ModalOverlay.ModalContent>
                <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Width="600"
                    MaxHeight="650"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    DataContext="{Binding ViewingOrder}" x:CompileBindings="False">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Modal Header -->
                    <Border Grid.Row="0" Padding="24,20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc 'Order Details'}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding PoNumber}"
                                           FontSize="13"
                                           FontFamily="Consolas, monospace"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1" Classes="icon-button" Command="{Binding $parent[UserControl].DataContext.CloseViewModalCommand}">
                                <PathIcon Data="{x:Static icons:Icons.Close}" Width="20" Height="20" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Modal Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24" Spacing="20">
                            <!-- Status Badge -->
                            <Border Background="{Binding StatusBackground}"
                                    CornerRadius="6"
                                    Padding="12,8"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding StatusDisplay}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding StatusColor}" />
                            </Border>

                            <!-- Supplier Info -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{loc:Loc 'Supplier'}" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding SupplierName}"
                                           FontSize="16" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>

                            <!-- Dates -->
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{loc:Loc 'Order Date'}" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
                                    <TextBlock Text="{Binding DateDisplay}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{loc:Loc 'Expected Delivery'}" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
                                    <TextBlock Text="{Binding ExpectedDisplay}"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </StackPanel>
                            </Grid>

                            <!-- Line Items -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="{loc:Loc 'Line Items'}" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        CornerRadius="8"
                                        Padding="12">
                                    <StackPanel>
                                        <!-- Header -->
                                        <Grid ColumnDefinitions="2*,*,*,*" Margin="0,0,0,8">
                                            <TextBlock Grid.Column="0" Text="{loc:Loc 'Product'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="{loc:Loc 'Qty'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" />
                                            <TextBlock Grid.Column="2" Text="{loc:Loc 'Unit Cost'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" />
                                            <TextBlock Grid.Column="3" Text="{loc:Loc 'Total'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding $parent[UserControl].DataContext.ViewLineItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="vm:ViewLineItemDisplay">
                                                    <Border Margin="0,4" Padding="8" Background="{DynamicResource SurfaceBrush}" CornerRadius="6">
                                                        <Grid ColumnDefinitions="2*,*,*,*">
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding ProductName}" FontWeight="Medium" />
                                                                <TextBlock Text="{Binding ProductSku}" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding QuantityDisplay}" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="2" Text="{Binding UnitCostDisplay}" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="3" Text="{Binding TotalDisplay}" FontWeight="Medium" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Total -->
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    CornerRadius="8"
                                    Padding="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{loc:Loc 'Total'}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Column="1" Text="{Binding TotalDisplay}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource PrimaryBrush}" />
                                </Grid>
                            </Border>

                            <!-- Notes -->
                            <StackPanel Spacing="4" IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{loc:Loc 'Notes'}" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
                                <TextBlock Text="{Binding Notes}"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Modal Footer -->
                    <Border Grid.Row="2" Padding="24,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <Button Classes="secondary-button" Content="{loc:Loc 'Close'}" Command="{Binding $parent[UserControl].DataContext.CloseViewModalCommand}" HorizontalAlignment="Right" />
                    </Border>
                </Grid>
                </Border>
            </controls:ModalOverlay.ModalContent>
        </controls:ModalOverlay>

        <!-- Receive Order Modal -->
        <controls:ModalOverlay IsOpen="{Binding IsReceiveModalOpen}">
            <controls:ModalOverlay.ModalContent>
                <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="12" Width="600"
                    MaxHeight="550"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Modal Header -->
                    <Border Grid.Row="0" Padding="24,20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc 'Receive Items'}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock DataContext="{Binding ReceivingOrder}" x:CompileBindings="False"
                                           Text="{Binding PoNumber}"
                                           FontSize="13"
                                           FontFamily="Consolas, monospace"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1" Classes="icon-button" Command="{Binding CloseReceiveModalCommand}">
                                <PathIcon Data="{x:Static icons:Icons.Close}" Width="20" Height="20" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Modal Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24" Spacing="16">
                            <TextBlock Text="{loc:Loc 'Enter the quantity received for each item. This will update your inventory.'}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <!-- Receive Line Items -->
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    CornerRadius="8"
                                    Padding="12">
                                <StackPanel>
                                    <!-- Header -->
                                    <Grid ColumnDefinitions="2*,60,60,60,80" Margin="0,0,0,8">
                                        <TextBlock Grid.Column="0" Text="{loc:Loc 'Product'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{loc:Loc 'Ordered'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{loc:Loc 'Received'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{loc:Loc 'Remaining'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{loc:Loc 'Receiving'}" FontSize="12" FontWeight="Medium" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding ReceiveLineItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:ReceiveLineItemViewModel">
                                                <Border Margin="0,4" Padding="8" Background="{DynamicResource SurfaceBrush}" CornerRadius="6">
                                                    <Grid ColumnDefinitions="2*,60,60,60,80">
                                                        <TextBlock Grid.Column="0" Text="{Binding ProductName}" FontWeight="Medium" VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Ordered}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="{Binding Received}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        <TextBlock Grid.Column="3" Text="{Binding Remaining}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Medium" Foreground="{DynamicResource PrimaryBrush}" />
                                                        <TextBox Grid.Column="4"
                                                                 Text="{Binding ReceivingQuantity, Mode=TwoWay}"
                                                                 Classes="form-input-compact"
                                                                 HorizontalAlignment="Stretch"
                                                                 HorizontalContentAlignment="Center"
                                                                 MaxLength="7" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Error Message -->
                            <TextBlock Text="{Binding ReceiveModalError}"
                                       FontSize="12"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       IsVisible="{Binding ReceiveModalError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Modal Footer -->
                    <Border Grid.Row="2" Padding="24,16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                            <Button Classes="secondary-button" Content="{loc:Loc 'Cancel'}" Command="{Binding CloseReceiveModalCommand}" />
                            <Button Classes="success-button" Content="{loc:Loc 'Confirm Received'}" Command="{Binding ConfirmReceiveCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>
                </Border>
            </controls:ModalOverlay.ModalContent>
        </controls:ModalOverlay>

        <!-- Filter Modal -->
        <controls:ModalOverlay IsOpen="{Binding IsFilterModalOpen}"
                               ClosingCommand="{Binding RequestCloseFilterModalCommand}">
            <controls:ModalOverlay.ModalContent>
                <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Width="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <!-- Modal Header -->
                    <Border Padding="24,20"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{loc:Loc 'Filter Purchase Orders'}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Button Grid.Column="1"
                                    Classes="icon-button"
                                    Command="{Binding CloseFilterModalCommand}">
                                <PathIcon Data="{x:Static icons:Icons.Close}"
                                          Width="20" Height="20" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Modal Content -->
                    <StackPanel Spacing="16" Margin="24">
                        <!-- Date Range -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="{loc:Loc 'Date Range'}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <Grid ColumnDefinitions="*,8,*">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{loc:Loc 'From'}" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
                                    <DatePicker SelectedDate="{Binding FilterStartDate}" Classes="form-datepicker" MinWidth="0" HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{loc:Loc 'To'}" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
                                    <DatePicker SelectedDate="{Binding FilterEndDate}" Classes="form-datepicker" MinWidth="0" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Supplier -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Loc 'Supplier'}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <controls:SearchableDropdown ItemsSource="{Binding FilterSupplierOptions}"
                                                         SelectedItem="{Binding FilterSupplier}"
                                                         Placeholder="{loc:Loc 'Search suppliers...'}" />
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="{loc:Loc 'Status'}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <ComboBox ItemsSource="{Binding FilterStatusOptions}"
                                      SelectedItem="{Binding FilterStatus}"
                                      Classes="form-combobox"
                                      HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource TranslateConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- Modal Footer -->
                    <Border Padding="24,16"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <Button Grid.Column="0"
                                    Content="{loc:Loc 'Clear Filters'}"
                                    Classes="secondary-button"
                                    HorizontalAlignment="Left"
                                    Command="{Binding ClearFiltersCommand}" />
                            <Button Grid.Column="2"
                                    Content="{loc:Loc 'Cancel'}"
                                    Classes="secondary-button"
                                    Margin="0,0,12,0"
                                    Command="{Binding CloseFilterModalCommand}" />
                            <Button Grid.Column="3"
                                    Content="{loc:Loc 'Apply Filters'}"
                                    Classes="primary-button"
                                    Command="{Binding ApplyFiltersCommand}" />
                        </Grid>
                    </Border>
                </StackPanel>
                </Border>
            </controls:ModalOverlay.ModalContent>
        </controls:ModalOverlay>

        <!-- Send Purchase Order Modal -->
        <controls:ModalOverlay IsOpen="{Binding IsSendModalOpen}"
                               ClosingCommand="{Binding CloseSendModalCommand}">
            <controls:ModalOverlay.ModalContent>
                <Border Width="{Binding SendModalWidth}"
                        Height="{Binding SendModalHeight}"
                        Margin="{Binding IsSendFullscreen, Converter={x:Static local:BoolConverters.ToFullscreenMargin}}"
                        HorizontalAlignment="{Binding IsSendFullscreen, Converter={x:Static local:BoolConverters.ToFullscreenHorizontalAlignment}}"
                        VerticalAlignment="{Binding IsSendFullscreen, Converter={x:Static local:BoolConverters.ToFullscreenVerticalAlignment}}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" CornerRadius="12"
                        BoxShadow="0 8 32 0 #40000000">
                    <Border.Transitions>
                        <Transitions>
                            <ThicknessTransition Property="Margin" Duration="0:0:0.2" Easing="CubicEaseInOut" />
                        </Transitions>
                    </Border.Transitions>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <!-- Header -->
                        <Border Grid.Row="0" Padding="24,20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc 'Send Purchase Order'}"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{loc:Loc 'Email this purchase order to the supplier with the PDF attached.'}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </StackPanel>
                                <Button Grid.Column="1" Classes="icon-button" Command="{Binding CloseSendModalCommand}">
                                    <PathIcon Data="{x:Static icons:Icons.Close}" Width="20" Height="20" />
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Body: two-column layout (email form | PDF preview) -->
                        <Grid Grid.Row="1" ColumnDefinitions="2*,3*" IsVisible="{Binding !IsSendSuccess}">
                            <!-- Email Form -->
                            <ScrollViewer Grid.Column="0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="24" Spacing="14">
                                    <!-- To -->
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                <Run Text="{loc:Loc 'To'}" /><Run Text=" *" Foreground="{DynamicResource ErrorBrush}" />
                                            </TextBlock>
                                            <Button Grid.Column="1" Classes="link-button" Command="{Binding ToggleCcBccCommand}">
                                                <TextBlock Text="{loc:Loc 'Cc/Bcc'}" FontSize="12" />
                                            </Button>
                                        </Grid>
                                        <TextBox Text="{Binding SendRecipientEmail, Mode=TwoWay}"
                                                 Classes="form-input"
                                                 PlaceholderText="supplier@example.com" />
                                    </StackPanel>

                                    <!-- Cc / Bcc -->
                                    <StackPanel Spacing="10" IsVisible="{Binding IsSendCcBccExpanded}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{loc:Loc 'Cc'}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBox Text="{Binding SendCcEmail, Mode=TwoWay}"
                                                     Classes="form-input"
                                                     PlaceholderText="cc@example.com" />
                                        </StackPanel>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{loc:Loc 'Bcc'}" FontSize="13" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBox Text="{Binding SendBccEmail, Mode=TwoWay}"
                                                     Classes="form-input"
                                                     PlaceholderText="bcc@example.com" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Subject -->
                                    <StackPanel Spacing="6">
                                        <TextBlock FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}">
                                            <Run Text="{loc:Loc 'Subject'}" /><Run Text=" *" Foreground="{DynamicResource ErrorBrush}" />
                                        </TextBlock>
                                        <TextBox Text="{Binding SendSubject, Mode=TwoWay}"
                                                 Classes="form-input"
                                                 MaxLength="200" />
                                    </StackPanel>

                                    <!-- Message -->
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{loc:Loc 'Message'}" FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBox Text="{Binding SendBody, Mode=TwoWay}"
                                                 Classes="form-input"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="160"
                                                 MaxHeight="240" />
                                    </StackPanel>

                                    <!-- Attachment chip -->
                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{x:Static icons:Icons.Reports}"
                                                      Width="16" Height="16"
                                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Margin="8,0,0,0"
                                                       Text="{Binding SendPdfFilename}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Classes="icon-button"
                                                    Command="{Binding DownloadSendPdfCommand}"
                                                    ToolTip.Tip="{loc:Loc 'Download PDF'}">
                                                <PathIcon Data="{x:Static icons:Icons.Download}" Width="14" Height="14" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- PDF Preview Panel -->
                            <Border Grid.Column="1"
                                    Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1,0,0,0"
                                    ClipToBounds="True">
                                <Grid RowDefinitions="*,Auto">
                                    <!-- Loading placeholder -->
                                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Spacing="10"
                                                IsVisible="{Binding SendPdfPreview, Converter={x:Static ObjectConverters.IsNull}}">
                                        <ProgressBar IsIndeterminate="True" Width="160" Height="3" />
                                        <TextBlock Text="{loc:Loc 'Generating PDF preview...'}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>
                                    <!-- Zoomable / pannable PDF preview -->
                                    <Border Grid.Row="0"
                                            Background="#1A000000"
                                            Margin="8,8,8,4"
                                            CornerRadius="4"
                                            ClipToBounds="True"
                                            IsVisible="{Binding SendPdfPreview, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <ScrollViewer x:Name="SendPdfPreviewScrollViewer"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Cursor="Hand">
                                            <LayoutTransformControl x:Name="SendPdfPreviewZoomTransform"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center">
                                                <Border x:Name="SendPdfPreviewCard"
                                                        Background="White"
                                                        BoxShadow="0 4 12 0 #20000000"
                                                        CornerRadius="2">
                                                    <Image x:Name="SendPdfPreviewImage"
                                                           Source="{Binding SendPdfPreview}"
                                                           Stretch="None" />
                                                </Border>
                                            </LayoutTransformControl>
                                        </ScrollViewer>
                                    </Border>
                                    <!-- Zoom Controls -->
                                    <StackPanel Grid.Row="1"
                                                Orientation="Horizontal"
                                                Spacing="2"
                                                HorizontalAlignment="Center"
                                                Margin="4,0,4,8"
                                                IsVisible="{Binding SendPdfPreview, Converter={x:Static ObjectConverters.IsNotNull}}">
                                        <Button Classes="icon-button"
                                                Click="SendPdfPreviewZoomOut_Click"
                                                ToolTip.Tip="{loc:Loc 'Zoom Out'}">
                                            <PathIcon Data="{x:Static icons:Icons.ZoomOut}"
                                                      Width="14" Height="14" />
                                        </Button>
                                        <Slider x:Name="SendPdfPreviewZoomSlider"
                                                Minimum="0.01"
                                                Maximum="4.0"
                                                Width="80"
                                                VerticalAlignment="Center"
                                                ValueChanged="SendPdfPreviewZoomSlider_ValueChanged" />
                                        <Button Classes="icon-button"
                                                Click="SendPdfPreviewZoomIn_Click"
                                                ToolTip.Tip="{loc:Loc 'Zoom In'}">
                                            <PathIcon Data="{x:Static icons:Icons.ZoomIn}"
                                                      Width="14" Height="14" />
                                        </Button>
                                        <TextBlock x:Name="SendPdfPreviewZoomText"
                                                   Text="100%"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Width="38"
                                                   TextAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <Button Classes="icon-button"
                                                Click="SendPdfPreviewFitToWindow_Click"
                                                ToolTip.Tip="{loc:Loc 'Fit to Window'}">
                                            <PathIcon Data="{x:Static icons:Icons.ScanFocus}"
                                                      Width="14" Height="14" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Success state -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Spacing="14"
                                    IsVisible="{Binding IsSendSuccess}">
                            <Border Width="64" Height="64" CornerRadius="32"
                                    Background="{DynamicResource SuccessLightBrush}"
                                    HorizontalAlignment="Center">
                                <PathIcon Data="{x:Static icons:Icons.Check}"
                                          Width="32" Height="32"
                                          Foreground="{DynamicResource SuccessBrush}" />
                            </Border>
                            <TextBlock Text="{loc:Loc 'Purchase order sent.'}"
                                       FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{loc:Loc 'The supplier will receive the PDF by email.'}"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>

                        <!-- Sending overlay -->
                        <Border Grid.Row="0" Grid.RowSpan="3"
                                Background="{DynamicResource SurfaceBrush}"
                                CornerRadius="12"
                                Cursor="Arrow"
                                IsVisible="{Binding IsSending}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                                <ProgressBar IsIndeterminate="True" Width="220" Height="4" />
                                <TextBlock Text="{loc:Loc 'Sending purchase order...'}"
                                           FontSize="16" FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{loc:Loc 'Emailing the supplier with the PDF attached.'}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" MaxWidth="320" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Footer -->
                        <Border Grid.Row="2" Padding="24,16"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel Spacing="12">
                                <!-- Error Banner -->
                                <Border Background="{DynamicResource ErrorLightBrush}"
                                        BorderBrush="{DynamicResource ErrorBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="12,8"
                                        IsVisible="{Binding HasSendError}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <PathIcon Grid.Column="0" Data="{x:Static icons:Icons.WarningCircle}"
                                                  Foreground="{DynamicResource ErrorBrush}"
                                                  Width="18" Height="18" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding SendError}"
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   FontSize="13" Margin="10,0"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                        <Button Grid.Column="2" Content="✕"
                                                Command="{Binding DismissSendErrorCommand}"
                                                Background="Transparent"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                BorderThickness="0" Padding="4"
                                                VerticalAlignment="Center" Cursor="Hand" />
                                    </Grid>
                                </Border>
                                <!-- Footer Buttons -->
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                    <Button Grid.Column="0" Classes="icon-button"
                                            ToolTip.Tip="{loc:Loc 'Toggle Fullscreen'}"
                                            Command="{Binding ToggleSendFullscreenCommand}"
                                            IsVisible="{Binding !IsSendSuccess}">
                                        <PathIcon Data="{Binding IsSendFullscreen, Converter={x:Static local:BoolConverters.ToFullscreenIcon}}"
                                                  Width="16" Height="16" />
                                    </Button>
                                    <Button Grid.Column="1" Classes="secondary-button"
                                            Margin="12,0,0,0"
                                            Content="{loc:Loc 'Download PDF'}"
                                            Command="{Binding DownloadSendPdfCommand}"
                                            IsVisible="{Binding !IsSendSuccess}" />
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12">
                                        <Button Classes="secondary-button"
                                                Content="{loc:Loc 'Close'}"
                                                Command="{Binding CloseSendModalCommand}" />
                                        <Button Classes="primary-button"
                                                Content="{loc:Loc 'Send'}"
                                                Command="{Binding SendOrderCommand}"
                                                IsVisible="{Binding !IsSendSuccess}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </controls:ModalOverlay.ModalContent>
        </controls:ModalOverlay>

    </Panel>

    <UserControl.Styles>
        <!-- Small Icon Button -->
        <Style Selector="Button.icon-button-small">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.icon-button-small /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.icon-button-small:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>
        <Style Selector="Button.icon-button-small PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="Button.icon-button-small.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ErrorLightBrush}" />
        </Style>
        <Style Selector="Button.icon-button-small.danger:pointerover PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
        </Style>
    </UserControl.Styles>
</UserControl>
