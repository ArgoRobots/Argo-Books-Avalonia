<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArgoBooks.ViewModels"
             xmlns:loc="using:ArgoBooks.Localization"
             xmlns:controls="using:ArgoBooks.Controls"
             xmlns:local="using:ArgoBooks"
             xmlns:icons="using:ArgoBooks"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="ArgoBooks.Modals.UpgradeModal"
             x:DataType="vm:UpgradeModalViewModel">

    <Design.DataContext>
        <vm:UpgradeModalViewModel />
    </Design.DataContext>

    <Panel>
        <!-- Upgrade Modal -->
        <controls:ModalOverlay IsOpen="{Binding IsOpen}" ClosingCommand="{Binding CloseCommand}">
            <controls:ModalOverlay.ModalContent>
                <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Width="740"
                    MaxHeight="750"
                    VerticalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000">

                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header -->
                    <Border Grid.Row="0"
                            Padding="24,20"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{loc:Loc 'Upgrade Your Plan'}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Button Grid.Column="1"
                                    Classes="icon-button"
                                    Command="{Binding CloseCommand}">
                                <PathIcon Data="{x:Static local:Icons.Close}"
                                          Width="20" Height="20" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                        <Panel>
                            <!-- Loading Spinner -->
                            <StackPanel IsVisible="{Binding IsLoadingPlans}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="12"
                                        Margin="48">
                                <ProgressBar IsIndeterminate="True"
                                             Width="200"
                                             HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Loc 'Loading plans...'}"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- Offline Message -->
                            <StackPanel IsVisible="{Binding IsOffline}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="12"
                                        Margin="48">
                                <PathIcon Data="{x:Static local:Icons.WifiOff}"
                                          Width="48" Height="48"
                                          Foreground="{DynamicResource TextTertiaryBrush}"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Loc 'No Connection'}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Loc 'Unable to load plan details. Please check your internet connection and try again.'}"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="360" />
                            </StackPanel>

                            <!-- Load Error Message -->
                            <StackPanel IsVisible="{Binding HasLoadError}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="12"
                                        Margin="48">
                                <PathIcon Data="{x:Static local:Icons.LostDamaged}"
                                          Width="48" Height="48"
                                          Foreground="{DynamicResource ErrorBrush}"
                                          HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Loc 'Unable to Load Plans'}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{loc:Loc 'Could not load plan details from the server. Please try again later.'}"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="360" />
                            </StackPanel>

                            <!-- Plan Cards (only shown when loaded successfully) -->
                            <StackPanel Margin="24" Spacing="16" IsVisible="{Binding ShowPlans}">

                                <!-- Billing cycle toggle (above both cards, centered) -->
                                <Border Classes="cycle-toggle" HorizontalAlignment="Center">
                                    <Grid ColumnDefinitions="*,*">
                                        <Button Grid.Column="0"
                                                Classes="cycle-option"
                                                Classes.active="{Binding IsYearlyBilling}"
                                                Command="{Binding SelectYearlyBillingCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <TextBlock Text="{loc:Loc Yearly}" VerticalAlignment="Center" />
                                                <Border Classes="save-pill">
                                                    <TextBlock Text="{Binding YearlySavingsPercentDisplay}" />
                                                </Border>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Classes="cycle-option"
                                                Classes.active="{Binding IsMonthlyBilling}"
                                                Command="{Binding SelectMonthlyBillingCommand}"
                                                Content="{loc:Loc Monthly}" />
                                    </Grid>
                                </Border>

                                <!-- Cards row -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                                <!-- Free Plan -->
                                <Border Classes="plan-card" Width="340" IsVisible="{Binding !HasPremium}">
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <!-- Plan Header -->
                                        <StackPanel Grid.Row="0" Spacing="4">
                                            <TextBlock Text="{loc:Loc Free}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="$0"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="{loc:Loc 'Current Plan'}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Features (from API) -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding FreePlanFeatures}" Margin="0,16,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="feature-item">
                                                        <Grid ColumnDefinitions="Auto,*">
                                                            <PathIcon Grid.Column="0"
                                                                      Data="{x:Static local:Icons.Check}"
                                                                      Width="14" Height="14"
                                                                      Foreground="{DynamicResource TextTertiaryBrush}"
                                                                      Margin="0,0,10,0" />
                                                            <TextBlock Grid.Column="1" Text="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Current Plan Label -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{loc:Loc 'Current Plan'}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,16,0,0" />
                                    </Grid>
                                </Border>

                                <!-- Premium Plan -->
                                <Border Classes="plan-card" Width="340">
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <!-- Plan Header -->
                                        <Panel Grid.Row="0">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{loc:Loc Premium}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />

                                                <!-- Monthly price -->
                                                <StackPanel HorizontalAlignment="Center"
                                                            Spacing="2"
                                                            IsVisible="{Binding IsMonthlyBilling}">
                                                    <!-- Invisible placeholder to match the yearly view's strikethrough,
                                                         so the card doesn't change height when toggling cycles. -->
                                                    <TextBlock Text="{Binding PremiumMonthlyStrike}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextDecorations="Strikethrough"
                                                               HorizontalAlignment="Center"
                                                               Opacity="0"
                                                               IsHitTestVisible="False" />
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                                        <TextBlock Text="{Binding PremiumMonthlyPrice}"
                                                                   FontSize="28"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource PrimaryBrush}" />
                                                        <TextBlock Text="{Binding PremiumBillingPeriod}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   VerticalAlignment="Bottom"
                                                                   Margin="0,0,0,5" />
                                                    </StackPanel>
                                                    <TextBlock Text="{loc:Loc 'Billed monthly'}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>

                                                <!-- Yearly price (default) -->
                                                <StackPanel HorizontalAlignment="Center"
                                                            Spacing="2"
                                                            IsVisible="{Binding IsYearlyBilling}">
                                                    <TextBlock Text="{Binding PremiumMonthlyStrike}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextDecorations="Strikethrough"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                                        <TextBlock Text="{Binding PremiumYearlyPerMonth}"
                                                                   FontSize="28"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource PrimaryBrush}" />
                                                        <TextBlock Text="{Binding PremiumBillingPeriod}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   VerticalAlignment="Bottom"
                                                                   Margin="0,0,0,5" />
                                                    </StackPanel>
                                                    <TextBlock Text="{loc:Loc 'Billed annually'}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Active Badge (when has Premium) -->
                                            <Border Background="{DynamicResource SuccessBrush}"
                                                    CornerRadius="4"
                                                    Padding="8,4"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    IsVisible="{Binding ShowPremiumActive}">
                                                <TextBlock Text="{loc:Loc Active}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="White" />
                                            </Border>
                                        </Panel>

                                        <!-- Features (from API) -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding PremiumPlanFeatures}" Margin="0,16,0,16">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="feature-item">
                                                        <Grid ColumnDefinitions="Auto,*">
                                                            <PathIcon Grid.Column="0"
                                                                      Data="{x:Static local:Icons.Check}"
                                                                      Width="14" Height="14"
                                                                      Foreground="{DynamicResource SuccessBrush}"
                                                                      Margin="0,0,10,0" />
                                                            <TextBlock Grid.Column="1" Text="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Grid.Row="2" Spacing="8">
                                            <!-- Select Premium Button (only when doesn't have Premium) -->
                                            <Button Classes="primary-button"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Command="{Binding SelectPremiumCommand}"
                                                    Content="{loc:Loc 'Select Premium'}"
                                                    IsVisible="{Binding ShowSelectPremium}" />
                                            <Button Classes="secondary-button"
                                                    HorizontalAlignment="Stretch"
                                                    HorizontalContentAlignment="Center"
                                                    Command="{Binding CancelSubscriptionCommand}"
                                                    Content="{loc:Loc 'Manage Subscription'}"
                                                    IsVisible="{Binding ShowCancelPremium}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                </StackPanel>
                            </StackPanel>
                        </Panel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2"
                            Padding="24,20"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            IsVisible="{Binding ShowPlans}">
                        <Button Classes="primary-button"
                                HorizontalAlignment="Right"
                                HorizontalContentAlignment="Center"
                                Command="{Binding OpenEnterKeyCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{x:Static icons:Icons.Key}"
                                          Width="16" Height="16" />
                                <TextBlock Text="{loc:Loc 'Enter a Key'}" />
                            </StackPanel>
                        </Button>
                    </Border>
                </Grid>
                </Border>
            </controls:ModalOverlay.ModalContent>
        </controls:ModalOverlay>

        <!-- Enter Key Modal -->
        <controls:ModalOverlay IsOpen="{Binding IsEnterKeyModalOpen}" ClosingCommand="{Binding RequestCloseEnterKeyCommand}">
            <controls:ModalOverlay.ModalContent>
                <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Width="420"
                    VerticalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000">

                <Panel>
                    <!-- Normal Entry View -->
                    <Grid RowDefinitions="Auto,*,Auto"
                          IsVisible="{Binding !IsVerificationSuccess}">
                        <!-- Header -->
                        <Border Grid.Row="0"
                                Padding="24,20"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{loc:Loc 'Enter License Key'}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Button Grid.Column="1"
                                        Classes="icon-button"
                                        Command="{Binding CloseEnterKeyCommand}">
                                    <PathIcon Data="{x:Static icons:Icons.Close}"
                                              Width="20" Height="20" />
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Body -->
                        <StackPanel Grid.Row="1" Margin="24" Spacing="16">
                            <TextBlock Text="{loc:Loc 'Enter your license key to activate your premium features.'}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <StackPanel Spacing="6">
                                <TextBlock Text="{loc:Loc 'License Key'}"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <TextBox x:Name="LicenseKeyTextBox"
                                         Text="{Binding LicenseKey, Mode=TwoWay}"
                                         PlaceholderText="XXXX-XXXX-XXXX-XXXX-XXXX"
                                         MaxLength="24"
                                         TextChanged="LicenseKeyTextBox_TextChanged"
                                         Classes="form-input license-key" />
                            </StackPanel>

                            <TextBlock Text="{Binding VerificationError}"
                                       FontSize="13"
                                       Foreground="{DynamicResource DangerBrush}"
                                       IsVisible="{Binding VerificationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        </StackPanel>

                        <!-- Footer -->
                        <Border Grid.Row="2"
                                Padding="24,16"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid ColumnDefinitions="Auto,*">
                                <Button Grid.Column="0"
                                        Classes="secondary-button"
                                        Command="{Binding GoBackToUpgradeCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <PathIcon Data="{x:Static icons:Icons.ChevronLeft}"
                                                  Width="14" Height="14" />
                                        <TextBlock Text="{loc:Loc Back}" />
                                    </StackPanel>
                                </Button>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Spacing="12">
                                <Button Classes="secondary-button"
                                        Content="{loc:Loc Cancel}"
                                        Command="{Binding CloseEnterKeyCommand}" />
                                <Button Classes="primary-button"
                                        Command="{Binding VerifyKeyCommand}"
                                        IsEnabled="{Binding !IsVerifying}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <PathIcon Data="{x:Static local:Icons.Check}"
                                                  Width="16" Height="16"
                                                  IsVisible="{Binding !IsVerifying}" />
                                        <TextBlock Text="{loc:Loc 'Verify Key'}" IsVisible="{Binding !IsVerifying}" />
                                        <TextBlock Text="{loc:Loc 'Verifying...'}" IsVisible="{Binding IsVerifying}" />
                                    </StackPanel>
                                </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Success Animation View -->
                    <StackPanel IsVisible="{Binding IsVerificationSuccess}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="24"
                                Margin="48">
                        <!-- Animated Success Circle with Glow -->
                        <Panel HorizontalAlignment="Center">
                            <!-- Glow effect behind the circle -->
                            <Border x:Name="SuccessGlow"
                                    Width="120" Height="120"
                                    CornerRadius="60"
                                    Opacity="0.4"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="{StaticResource SuccessColor}" Offset="0" />
                                        <GradientStop Color="Transparent" Offset="1" />
                                    </RadialGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0" ScaleY="0" />
                                </Border.RenderTransform>
                            </Border>
                            <!-- Main circle -->
                            <Border x:Name="SuccessCircle"
                                    Width="100" Height="100"
                                    CornerRadius="50"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    ClipToBounds="True"
                                    BoxShadow="0 4 20 0 #4022C55E">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="{StaticResource SuccessColor}" Offset="0" />
                                        <GradientStop Color="#16A34A" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0" ScaleY="0" />
                                </Border.RenderTransform>
                                <PathIcon Data="{x:Static local:Icons.Check}"
                                          Width="48" Height="48"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>
                        </Panel>

                        <!-- Success Text -->
                        <StackPanel x:Name="SuccessTextPanel" Spacing="8" HorizontalAlignment="Center" Opacity="0">
                            <StackPanel.RenderTransform>
                                <TranslateTransform Y="20" />
                            </StackPanel.RenderTransform>
                            <TextBlock Text="{loc:Loc 'License Activated!'}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding SuccessMessage}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="300" />
                        </StackPanel>

                        <!-- Continue Button (appears after 2 seconds with animation) -->
                        <Panel x:Name="ContinueButtonPanel"
                               HorizontalAlignment="Center"
                               Opacity="0"
                               IsHitTestVisible="{Binding ShowContinueButton}">
                            <Panel.RenderTransform>
                                <TranslateTransform Y="20" />
                            </Panel.RenderTransform>
                            <Button Classes="primary-button"
                                    Content="{loc:Loc Continue}"
                                    Command="{Binding ContinueAfterSuccessCommand}"
                                    HorizontalAlignment="Center"
                                    Padding="32,12" />
                        </Panel>
                    </StackPanel>
                </Panel>
                </Border>
            </controls:ModalOverlay.ModalContent>
        </controls:ModalOverlay>

    </Panel>

    <UserControl.Styles>
        <!-- Plan Card -->
        <Style Selector="Border.plan-card">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <!-- Billing cycle toggle (yearly | monthly) -->
        <Style Selector="Border.cycle-toggle">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="3" />
        </Style>

        <Style Selector="Button.cycle-option">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.cycle-option /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style Selector="Button.cycle-option:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        </Style>

        <Style Selector="Button.cycle-option.active">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        </Style>

        <Style Selector="Button.cycle-option.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BoxShadow" Value="0 1 4 0 #20000000" />
        </Style>

        <!-- "Save X%" pill on the yearly toggle button -->
        <Style Selector="Border.save-pill">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.save-pill TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- Feature Item -->
        <Style Selector="Border.feature-item">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,8" />
        </Style>
        <Style Selector="Border.feature-item TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style Selector="TextBox.license-key">
            <Setter Property="FontFamily" Value="Consolas, monospace" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="LetterSpacing" Value="2" />
        </Style>

        <!-- Outline Button -->
        <Style Selector="Button.outline-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.outline-button /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.outline-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>
        <Style Selector="Button.outline-button PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
    </UserControl.Styles>
</UserControl>
