<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArgoBooks.ViewModels"
             xmlns:controls="using:ArgoBooks.Controls"
             xmlns:dashboard="using:ArgoBooks.Controls.Dashboard"
             xmlns:loc="using:ArgoBooks.Localization"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="ArgoBooks.Views.DashboardPage"
             x:DataType="vm:DashboardPageViewModel">

    <Design.DataContext>
        <vm:DashboardPageViewModel />
    </Design.DataContext>

    <!-- Widget views are created in code-behind via WidgetFactory.CreateView() -->

    <UserControl.Styles>
        <!-- Card Style -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <!-- Edit toolbar button style -->
        <Style Selector="Button.edit-toolbar-btn">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.edit-toolbar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>
        <Style Selector="Button.edit-toolbar-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource SurfaceActiveBrush}" />
        </Style>
        <Style Selector="Button.edit-toolbar-btn.primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="Button.edit-toolbar-btn.primary:pointerover">
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <!-- Settings popup size buttons -->
        <Style Selector="Button.size-btn">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.size-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>
        <Style Selector="Button.size-btn:disabled">
            <Setter Property="Opacity" Value="0.4" />
        </Style>
        <Style Selector="Button.size-btn-selected">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>

    <!-- Main Content -->
    <Panel>
        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource BackgroundSecondaryBrush}">
            <StackPanel Margin="24" Spacing="24">
                <!-- Page Header -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{loc:Loc Dashboard}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding WelcomeSubtitle}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>

                    <!-- Edit Dashboard Button (hidden in edit mode) -->
                    <Button Grid.Column="1"
                            Classes="edit-toolbar-btn"
                            VerticalAlignment="Top"
                            Margin="0,0,12,0"
                            Command="{Binding LayoutViewModel.EnterEditModeCommand}"
                            IsVisible="{Binding !LayoutViewModel.IsEditMode}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                      Width="14" Height="14"
                                      Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{loc:Loc 'Edit Dashboard'}" FontSize="13" />
                        </StackPanel>
                    </Button>

                    <!-- Chart Type Selector -->
                    <controls:ChartTypeSelector Grid.Column="2" VerticalAlignment="Top" Margin="0,0,16,0" />

                    <!-- Date Range Selector -->
                    <controls:DateRangeSelector Grid.Column="3" VerticalAlignment="Top" />
                </Grid>

                <!-- Edit Mode Toolbar -->
                <Border Classes="card"
                        Padding="12,8"
                        IsVisible="{Binding LayoutViewModel.IsEditMode}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Left: Add Widget and Reset -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Button Classes="edit-toolbar-btn"
                                    Command="{Binding LayoutViewModel.OpenCatalogCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="+" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                                    <TextBlock Text="{loc:Loc 'Add Widget'}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Classes="edit-toolbar-btn"
                                    Command="{Binding LayoutViewModel.ResetToDefaultCommand}">
                                <TextBlock Text="{loc:Loc 'Reset to Default'}" />
                            </Button>
                        </StackPanel>

                        <!-- Right: Cancel and Save -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Classes="edit-toolbar-btn"
                                    Command="{Binding LayoutViewModel.CancelEditCommand}">
                                <TextBlock Text="{loc:Loc Cancel}" />
                            </Button>
                            <Button Classes="edit-toolbar-btn primary"
                                    Command="{Binding LayoutViewModel.SaveEditCommand}">
                                <TextBlock Text="{loc:Loc Save}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Date Range Message -->
                <Border Classes="card"
                        Padding="16"
                        IsVisible="{Binding ShowFinancialDateRangeMessage}">
                    <controls:ChartEmptyState
                        ShowDateRangeMessage="True" />
                </Border>

                <!-- Empty dashboard message (shown when all widgets are removed) -->
                <Border IsVisible="{Binding !LayoutViewModel.HasWidgets}"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="40"
                        HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12">
                        <TextBlock Text="Your dashboard is empty"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Click 'Edit Dashboard' to add widgets and customize your view."
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="400" />
                        <Button Content="Edit Dashboard"
                                Classes="edit-toolbar-btn primary"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0"
                                Command="{Binding LayoutViewModel.EnterEditModeCommand}" />
                    </StackPanel>
                </Border>

                <!-- Widget Rows (wrapped in Panel so the drag ghost can overlay) -->
                <Panel IsVisible="{Binding LayoutViewModel.HasWidgets}">
                    <StackPanel x:Name="RowsContainer"
                                Spacing="12" />
                </Panel>

                <!-- Add Row button (edit mode only) -->
                <Button Classes="edit-toolbar-btn"
                        Command="{Binding LayoutViewModel.AddRowCommand}"
                        IsVisible="{Binding LayoutViewModel.IsEditMode}"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="+" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="Add Row" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Bottom Spacing -->
                <Border Height="24" />
            </StackPanel>
        </ScrollViewer>

        <!-- Global Widget Settings Popup (rendered on top of everything) -->
        <Border x:Name="SettingsBackdrop"
                Background="Transparent"
                IsVisible="False"
                ZIndex="200" />
        <Border x:Name="SettingsPopup"
                IsVisible="False"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                MaxWidth="320"
                ZIndex="201"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                BoxShadow="0 4 16 0 #30000000">
            <StackPanel x:Name="SettingsContent" Spacing="8" MaxHeight="400" />
        </Border>

        <!-- Global Chart Context Menu (rendered on top of everything) -->
        <controls:ChartContextMenu x:Name="ChartContextMenu"
                                   IsOpen="{Binding IsChartContextMenuOpen}"
                                   MenuX="{Binding ChartContextMenuX}"
                                   MenuY="{Binding ChartContextMenuY}"
                                   ShowResetZoom="{Binding ShowChartResetZoom}"
                                   ShowExportOptions="{Binding ShowChartExportOptions}"
                                   ShowGoogleSheetsExport="{Binding ShowGoogleSheetsExport}"
                                   SaveChartAsImageCommand="{Binding SaveChartAsImageCommand}"
                                   ExportToGoogleSheetsCommand="{Binding ExportToGoogleSheetsCommand}"
                                   ExportToExcelCommand="{Binding ExportToExcelCommand}"
                                   ResetChartZoomCommand="{Binding ResetChartZoomCommand}"
                                   CloseCommand="{Binding HideChartContextMenuCommand}" />
    </Panel>
</UserControl>
