<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:icons="using:ArgoBooks"
             xmlns:loc="using:ArgoBooks.Localization"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="ArgoBooks.Controls.InvoicePreviewControl">

    <Grid RowDefinitions="*,Auto">
        <!-- Main content panel -->
        <Panel x:Name="RootPanel" Grid.Row="0">
            <!-- Cross-platform WebView for HTML/PDF rendering -->
            <NativeWebView x:Name="WebView"
                           IsVisible="False" />

            <!-- Linux Fallback (NativeWebView doesn't embed inline on Linux) -->
            <Border x:Name="FallbackPanel"
                    Background="{DynamicResource SurfaceAltBrush}"
                    CornerRadius="8"
                    Padding="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsVisible="False">
                <StackPanel Spacing="20" MaxWidth="400" HorizontalAlignment="Center">
                    <!-- Icon -->
                    <Border Background="{DynamicResource PrimaryBrush}"
                            Opacity="0.1"
                            CornerRadius="50"
                            Width="80" Height="80"
                            HorizontalAlignment="Center">
                        <PathIcon Data="{x:Static icons:Icons.OpenExternal}"
                                  Width="40" Height="40"
                                  Foreground="{DynamicResource PrimaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                    </Border>

                    <!-- Message -->
                    <TextBlock TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center">
                        <Run Text="{loc:Loc 'Click below to preview the invoice in your browser.'}" />
                    </TextBlock>

                    <!-- View in Browser Button -->
                    <Button x:Name="OpenInBrowserButton"
                            Classes="primary-button"
                            HorizontalAlignment="Center"
                            Padding="20,12"
                            Click="OpenInBrowserButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{x:Static icons:Icons.OpenExternal}" Width="16" Height="16" />
                            <TextBlock Text="{loc:Loc 'View in Browser'}" FontSize="14" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Panel>

        <!-- Zoom Controls Toolbar (shown at bottom when WebView is active) -->
        <Border x:Name="ZoomToolbar"
                Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,6"
                IsVisible="False">
            <Grid ColumnDefinitions="*,Auto,*">
                <!-- Centered zoom controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                    <!-- Fit to Window -->
                    <Button x:Name="FitToWindowButton"
                            Classes="icon-button"
                            ToolTip.Tip="{loc:Loc 'Fit to Window'}"
                            Click="FitToWindow_Click"
                            Padding="6">
                        <PathIcon Data="{x:Static icons:Icons.Fullscreen}"
                                  Width="14" Height="14" />
                    </Button>

                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2" />

                    <!-- Zoom Out -->
                    <Button x:Name="ZoomOutButton"
                            Classes="icon-button"
                            ToolTip.Tip="{loc:Loc 'Zoom Out'}"
                            Click="ZoomOut_Click"
                            Padding="6">
                        <PathIcon Data="{x:Static icons:Icons.Minus}"
                                  Width="14" Height="14" />
                    </Button>

                    <!-- Zoom Percentage Display -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="4"
                            Padding="8,4"
                            MinWidth="60">
                        <TextBlock x:Name="ZoomPercentageText"
                                   Text="100%"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Zoom In -->
                    <Button x:Name="ZoomInButton"
                            Classes="icon-button"
                            ToolTip.Tip="{loc:Loc 'Zoom In'}"
                            Click="ZoomIn_Click"
                            Padding="6">
                        <PathIcon Data="{x:Static icons:Icons.Add}"
                                  Width="14" Height="14" />
                    </Button>

                    <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="4,2" />

                    <!-- Reset Zoom -->
                    <Button x:Name="ResetZoomButton"
                            Classes="icon-button"
                            ToolTip.Tip="{loc:Loc 'Reset Zoom (100%)'}"
                            Click="ResetZoom_Click"
                            Padding="6"
                            MinWidth="28"
                            MinHeight="28">
                        <TextBlock Text="1:1"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <!-- Right side hint -->
                <TextBlock Grid.Column="2"
                           Text="{loc:Loc 'Ctrl+Scroll to zoom'}"
                           FontSize="11"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,4,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
