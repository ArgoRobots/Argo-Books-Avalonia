<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ArgoBooks.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:ArgoBooks.Controls"
        xmlns:modals="using:ArgoBooks.Modals"
        xmlns:views="using:ArgoBooks.Views"
        xmlns:loc="using:ArgoBooks.Localization"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="ArgoBooks.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Icon="/Assets/argo-logo.png"
        MinWidth="1024"
        MinHeight="680"
        Width="{Binding WindowWidth, Mode=TwoWay}"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        WindowState="{Binding WindowState, Mode=TwoWay}"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40"
        WindowDecorations="BorderOnly">

    <Window.Styles>
        <!-- Caption button hover effects -->
        <Style Selector="Button.caption-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#20FFFFFF" />
        </Style>
        <Style Selector="Button.caption-close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E81123" />
        </Style>
        <Style Selector="Button.caption-close:pointerover Line">
            <Setter Property="Stroke" Value="White" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Panel>
        <!-- Window Caption Buttons — high ZIndex so they're always visible above all overlays -->
        <StackPanel x:Name="WindowControls"
                    ZIndex="200"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Height="40">
            <!-- Minimize -->
            <Button Classes="caption-btn"
                    Click="MinimizeButton_Click"
                    Width="46" Height="40"
                    Background="Transparent"
                    BorderThickness="0" CornerRadius="0" Padding="0"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center">
                <!-- Horizontal line (filled rectangle) -->
                <Border Width="11" Height="1" Background="{DynamicResource TextPrimaryBrush}" />
            </Button>
            <!-- Maximize / Restore -->
            <Button Classes="caption-btn"
                    Click="MaximizeButton_Click"
                    Width="46" Height="40"
                    Background="Transparent"
                    BorderThickness="0" CornerRadius="0" Padding="0"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center">
                <Panel Width="10" Height="10">
                    <!-- Maximize icon (single rectangle) -->
                    <Border x:Name="MaximizeRect"
                            Width="10" Height="10"
                            BorderBrush="{DynamicResource TextPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="1.5" />
                    <!-- Restore icon (two overlapping rectangles — back one shows only top and right edges) -->
                    <Canvas x:Name="RestoreIcon" IsVisible="False" Width="11" Height="11">
                        <!-- Back rectangle (rendered first, behind front) -->
                        <Border Width="9" Height="9"
                                BorderBrush="{DynamicResource TextPrimaryBrush}"
                                BorderThickness="1"
                                CornerRadius="1.5"
                                Canvas.Left="2" Canvas.Top="0" />
                        <!-- Front rectangle (occludes back rectangle with solid background) -->
                        <Border Width="9" Height="9"
                                BorderBrush="{DynamicResource TextPrimaryBrush}"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderThickness="1"
                                CornerRadius="1.5"
                                Canvas.Left="0" Canvas.Top="2" />
                    </Canvas>
                </Panel>
            </Button>
            <!-- Close -->
            <Button Classes="caption-btn caption-close"
                    Click="CloseButton_Click"
                    Width="46" Height="40"
                    Background="Transparent"
                    BorderThickness="0" CornerRadius="0" Padding="0"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center">
                <Canvas Width="10" Height="10">
                    <Line StartPoint="0,0" EndPoint="10,10"
                          Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1" />
                    <Line StartPoint="10,0" EndPoint="0,10"
                          Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1" />
                </Canvas>
            </Button>
        </StackPanel>

        <!-- Modal Overlay (behind content but available for modals) -->
        <controls:ModalOverlay x:Name="ModalOverlay"
                               ZIndex="100" />

        <!-- Main Application Shell -->
        <DockPanel>
            <!-- Custom Title Bar (for platforms supporting client area extension) -->
            <Border DockPanel.Dock="Top"
                    Height="40"
                    Background="Transparent"
                    IsHitTestVisible="True"
                    x:Name="TitleBar">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- App Icon and Name -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <Image Source="/Assets/argo-logo.png"
                               Width="20" Height="20"
                               VerticalAlignment="Center" />
                        <TextBlock Text="{loc:Loc 'Argo Books'}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <!-- Separator and Company Name -->
                        <TextBlock Text="-"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding HasCompanyOpen}" />
                        <TextBlock Text="{Binding CurrentCompanyName}"
                                   FontSize="{StaticResource FontSizeSm}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding HasCompanyOpen}" />
                    </StackPanel>

                    <!-- Drag Region (center) -->
                    <Border Grid.Column="1"
                            Background="Transparent"
                            x:Name="DragRegion" />

                    <!-- Spacer for caption buttons (they're in a high-ZIndex layer above) -->
                    <Border Grid.Column="2" Width="138" />
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <ContentControl x:Name="MainContent" Content="{Binding CurrentView}" />
        </DockPanel>

        <!-- Welcome Screen (full-screen overlay when no company is open) -->
        <Panel IsVisible="{Binding ShowWelcomeScreen}" ZIndex="150">
            <views:WelcomeScreen DataContext="{Binding WelcomeScreenViewModel}" />
        </Panel>

        <!-- Password Prompt Modal (above WelcomeScreen so it can be shown when opening encrypted files) -->
        <modals:PasswordPromptModal DataContext="{Binding PasswordPromptModalViewModel}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    ZIndex="175" />

        <!-- Create Company Wizard (full-screen overlay above everything) -->
        <modals:CreateCompanyWizard DataContext="{Binding CreateCompanyViewModel}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    ZIndex="200" />

        <!-- Tutorial Welcome Overlay (shown on first launch after company opens) -->
        <modals:TutorialWelcomeOverlay DataContext="{Binding TutorialWelcomeViewModel}"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       ZIndex="210" />

        <!-- App Tour Overlay (interactive tour after welcome) -->
        <modals:AppTourOverlay DataContext="{Binding AppTourViewModel}"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               ZIndex="215" />

        <!-- Categories Page Tutorial Overlay -->
        <modals:CategoriesTutorialOverlay DataContext="{Binding CategoriesTutorialViewModel}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ZIndex="220" />

        <!-- Products Page Tutorial Overlay -->
        <modals:ProductsTutorialOverlay DataContext="{Binding ProductsTutorialViewModel}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ZIndex="220" />

        <!-- Loading Overlay (shows during long operations like import) -->
        <Border IsVisible="{Binding IsLoading}"
                Background="{DynamicResource OverlayBrush}"
                ZIndex="225"
                IsHitTestVisible="True">
            <Border Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="12"
                    Padding="40,28"
                    MinWidth="280"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BoxShadow="0 8 32 0 #40000000">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding LoadingMessage}"
                               FontSize="{StaticResource FontSizeMd}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <ProgressBar IsIndeterminate="{Binding IsLoadingIndeterminate}"
                                 Value="{Binding LoadingProgress}"
                                 Minimum="0"
                                 Maximum="100"
                                 Width="220"
                                 Height="4"
                                 Foreground="{DynamicResource PrimaryBrush}" />
                    <TextBlock Text="{Binding LoadingProgressText}"
                               IsVisible="{Binding LoadingProgressText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="{StaticResource FontSizeMd}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding LoadingDetail}"
                               IsVisible="{Binding LoadingDetail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               FontSize="{StaticResource FontSizeSm}"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               HorizontalAlignment="Center" />
                    <Button Content="{loc:Loc Cancel}"
                            Classes="secondary"
                            IsVisible="{Binding IsLoadingCancellable}"
                            Command="{Binding CancelLoadingCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Border>

        <!-- Receipt Viewer Modal -->
        <modals:ReceiptViewerModal DataContext="{Binding ReceiptViewerModalViewModel}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   ZIndex="200" />

        <!-- Confirmation Dialog (high level, can appear over any modal) -->
        <modals:ConfirmationDialog DataContext="{Binding ConfirmationDialogViewModel}"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   ZIndex="250" />

        <!-- Unsaved Changes Dialog (highest level, critical for data safety) -->
        <modals:UnsavedChangesDialog DataContext="{Binding UnsavedChangesDialogViewModel}"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     ZIndex="275" />
    </Panel>
</Window>
