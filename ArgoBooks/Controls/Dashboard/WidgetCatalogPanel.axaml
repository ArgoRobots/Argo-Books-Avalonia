<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArgoBooks.ViewModels.Dashboard"
             xmlns:icons="using:ArgoBooks"
             xmlns:loc="using:ArgoBooks.Localization"
             x:Class="ArgoBooks.Controls.Dashboard.WidgetCatalogPanel"
             x:DataType="vm:WidgetCatalogViewModel"
             IsVisible="{Binding IsOpen}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">

    <UserControl.Styles>
        <Style Selector="Button.catalog-item-btn">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.catalog-item-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
        </Style>
        <Style Selector="Button.catalog-item-btn.already-added">
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <!-- TabControl styling (matches SettingsModal) -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="TabControl /template/ Border#PART_InnerBorder">
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="4,12,4,10" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="True" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Height" Value="2" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="1" />
        </Style>
    </UserControl.Styles>

    <Panel>
        <!-- Semi-transparent backdrop -->
        <Border Background="{DynamicResource OverlayBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                PointerPressed="OnBackdropPointerPressed" />

        <!-- Centered modal panel -->
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLg}"
                Width="640"
                MaxHeight="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BoxShadow="0 8 24 0 #40000000">

            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Padding="24,20"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Add Widget"
                                   FontSize="{StaticResource FontSizeXl}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <Button Grid.Column="1"
                                Classes="icon"
                                Width="32" Height="32"
                                VerticalAlignment="Top"
                                Command="{Binding CloseCommand}"
                                ToolTip.Tip="{loc:Loc Close}">
                            <PathIcon Data="{x:Static icons:Icons.Close}"
                                      Width="18" Height="18"
                                      Foreground="{DynamicResource TextTertiaryBrush}" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Tabbed content -->
                <TabControl Margin="0,0,0,8">
                    <TabItem Header="Stat Cards">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="400">
                            <ItemsControl ItemsSource="{Binding StatCards}" Margin="20,8,20,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CatalogItem">
                                        <Button Classes="catalog-item-btn"
                                                Classes.already-added="{Binding IsAlreadyAdded}"
                                                Command="{Binding $parent[UserControl].((vm:WidgetCatalogViewModel)DataContext).AddWidgetCommand}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Definition.Icon}"
                                                           FontSize="20"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding Definition.Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding Definition.Description}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="Added" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                           IsVisible="{Binding IsAlreadyAdded}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Charts">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="400">
                            <ItemsControl ItemsSource="{Binding Charts}" Margin="20,8,20,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CatalogItem">
                                        <Button Classes="catalog-item-btn"
                                                Classes.already-added="{Binding IsAlreadyAdded}"
                                                Command="{Binding $parent[UserControl].((vm:WidgetCatalogViewModel)DataContext).AddWidgetCommand}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Definition.Icon}"
                                                           FontSize="20"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding Definition.Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding Definition.Description}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="Added" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                           IsVisible="{Binding IsAlreadyAdded}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Tables">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="400">
                            <ItemsControl ItemsSource="{Binding Tables}" Margin="20,8,20,12">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CatalogItem">
                                        <Button Classes="catalog-item-btn"
                                                Classes.already-added="{Binding IsAlreadyAdded}"
                                                Command="{Binding $parent[UserControl].((vm:WidgetCatalogViewModel)DataContext).AddWidgetCommand}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Definition.Icon}"
                                                           FontSize="20"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0" />
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{Binding Definition.Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <TextBlock Text="{Binding Definition.Description}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="Added" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                           IsVisible="{Binding IsAlreadyAdded}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>
    </Panel>
</UserControl>
