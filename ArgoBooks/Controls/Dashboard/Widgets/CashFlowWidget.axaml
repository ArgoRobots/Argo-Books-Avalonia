<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ArgoBooks.ViewModels.Dashboard"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:loc="using:ArgoBooks.Localization"
             x:Class="ArgoBooks.Controls.Dashboard.Widgets.CashFlowWidget"
             x:DataType="vm:CashFlowWidgetViewModel">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Header -->
            <Border Grid.Row="0"
                    Padding="20,16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc 'Cash Flow'}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="6"
                                IsVisible="{Binding HasData}">
                        <TextBlock Text="{loc:Loc 'Net:'}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding NetCashFlow}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chart -->
            <lvc:CartesianChart Grid.Row="2"
                                Series="{Binding Series}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                TooltipPosition="Top"
                                IsVisible="{Binding HasData}"
                                MinHeight="250" />

            <!-- Empty State -->
            <Border Grid.Row="2"
                    Padding="40"
                    IsVisible="{Binding HasNoData}">
                <TextBlock Text="{loc:Loc 'No cash flow data available'}"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Border>
</UserControl>
