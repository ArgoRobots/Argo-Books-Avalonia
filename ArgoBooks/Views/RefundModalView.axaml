<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ArgoBooks.ViewModels"
             xmlns:local="using:ArgoBooks"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="700"
             x:Class="ArgoBooks.Views.RefundModalView"
             x:DataType="vm:RefundModalViewModel">

    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Width="640"
            MaxHeight="700"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header -->
            <Border Grid.Row="0" Padding="24,18" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding InvoiceNumber, StringFormat='Refund Invoice {0}'}"
                                   FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding CustomerDisplay}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="icon-button" Command="{Binding CloseCommand}"
                            VerticalAlignment="Top">
                        <PathIcon Data="{x:Static local:Icons.Close}" Width="20" Height="20" />
                    </Button>
                </Grid>
            </Border>

            <!-- Body — switches by step -->
            <ScrollViewer Grid.Row="1" Padding="24,18" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- ========== STEP 1: line items ========== -->
                    <StackPanel IsVisible="{Binding IsLineItemsStep}" Spacing="16">

                        <!-- Payments -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Refund against:" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ItemsControl ItemsSource="{Binding Payments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:RefundablePaymentRow">
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Content="{Binding DisplayLabel}"
                                                  Margin="0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Line items -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="What to refund:" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <ItemsControl ItemsSource="{Binding LineRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:RefundableLineRow">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            <StackPanel Grid.Column="1" Margin="8,0">
                                                <TextBlock Text="{Binding Label}" />
                                                <TextBlock Text="{Binding Detail}" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat={}{0:C}}"
                                                       FontWeight="Medium" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Total -->
                        <Border Background="{DynamicResource AltSurfaceBrush}" Padding="12" CornerRadius="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Refund total" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RefundTotal, StringFormat={}{0:C}}"
                                           FontWeight="SemiBold" FontSize="16" />
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding LineItemsValidationMessage}"
                                   Foreground="#dc2626" FontSize="12"
                                   IsVisible="{Binding LineItemsValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Reason -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Reason (optional)" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBox Text="{Binding Reason, Mode=TwoWay}"
                                     PlaceholderText="e.g. Wrong item shipped"
                                     MaxLength="250"
                                     MinHeight="36" />
                        </StackPanel>
                    </StackPanel>

                    <!-- ========== STEP 2: enter code ========== -->
                    <StackPanel IsVisible="{Binding IsEnterCodeStep}" Spacing="16">
                        <TextBlock TextWrapping="Wrap"
                                   Text="{Binding MaskedEmail, StringFormat='A 6-digit code was sent to {0}. Enter it below to confirm the refund.'}" />
                        <TextBox Text="{Binding Code, Mode=TwoWay}"
                                 PlaceholderText="123456" MaxLength="6"
                                 FontSize="22" FontWeight="SemiBold"
                                 HorizontalContentAlignment="Center" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding CountdownDisplay}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Resend code"
                                    Command="{Binding ResendCodeCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#dc2626" FontSize="12"
                                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>

                    <!-- ========== STEP 3: cooling-off / polling ========== -->
                    <StackPanel IsVisible="{Binding IsPollingStep}" Spacing="14">
                        <TextBlock Text="Refund pending review" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CoolingOffMessage}" TextWrapping="Wrap" />
                        <ProgressBar IsIndeterminate="True" />
                    </StackPanel>

                    <!-- ========== TERMINAL: success ========== -->
                    <StackPanel IsVisible="{Binding IsSuccessStep}" Spacing="14">
                        <TextBlock Text="✓ Refund issued" FontSize="18" FontWeight="SemiBold"
                                   Foreground="#059669" />
                        <TextBlock Text="{Binding TerminalMessage}" TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- ========== TERMINAL: failure ========== -->
                    <StackPanel IsVisible="{Binding IsFailureStep}" Spacing="14">
                        <TextBlock Text="Refund did not complete" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#dc2626" />
                        <TextBlock Text="{Binding TerminalMessage}" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                    <ProgressBar Grid.Column="0" Width="120" Height="4" IsIndeterminate="True"
                                 IsVisible="{Binding IsBusy}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0" />

                    <!-- Step 1 footer -->
                    <Button Grid.Column="2" Content="Continue →"
                            IsVisible="{Binding IsLineItemsStep}"
                            IsEnabled="{Binding CanContinueFromLineItems}"
                            Command="{Binding ContinueCommand}"
                            Classes="primary" />

                    <!-- Step 2 footer -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding IsEnterCodeStep}">
                        <Button Content="← Back" Command="{Binding BackCommand}" />
                        <Button Content="Issue Refund" Classes="primary"
                                Command="{Binding SubmitCodeCommand}"
                                IsEnabled="{Binding CanSubmitCode}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
